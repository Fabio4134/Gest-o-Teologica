rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        ((exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'master') ||
         (request.auth.token.email == "fabio.bpereira40@gmail.com" && request.auth.token.email_verified == true));
    }
    
    function isTeacher() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher';
    }
    
    function isStudent() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'student';
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // User profiles
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin() || isTeacher();
      allow create: if isAuthenticated() && isOwner(userId) && 
        (request.resource.data.role == 'student' || 
         (request.resource.data.role == 'master' && request.auth.token.email == "fabio.bpereira40@gmail.com"));
      allow update: if isAdmin() || (isOwner(userId) && request.resource.data.role == resource.data.role);
    }

    // Students
    match /students/{studentId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isTeacher();
    }

    // Teachers
    match /teachers/{teacherId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Courses
    match /courses/{courseId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Subjects
    match /subjects/{subjectId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isTeacher();
    }

    // Attendance
    match /attendance/{attendanceId} {
      allow read: if isAdmin() || isTeacher() || isStudent();
      allow write: if isAdmin() || isTeacher();
    }

    // Question bank
    match /questions/{questionId} {
      allow read: if isAdmin() || isTeacher();
      allow write: if isAdmin() || isTeacher();
    }

    // Exams
    match /exams/{examId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isTeacher();
    }

    // Exam Results
    match /examResults/{resultId} {
      allow read: if isAdmin() || isTeacher() || (isAuthenticated() && resource.data.studentId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.studentId == request.auth.uid;
      allow update: if isAdmin();
    }

    // Financial Records
    match /finances/{recordId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.studentId == request.auth.uid);
      allow write: if isAdmin();
    }
  }
}
